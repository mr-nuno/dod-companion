{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      { "Name": "Seq", "Args": { "serverUrl": "http://localhost:5341" } }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",
  "Raven": {
    "Urls": [ "http://localhost:8080" ],
    "DatabaseName": "DodCompanion"
  },
  "RulesApi": {
    "BaseUrl": "https://pdf-search-api-1-0-0.onrender.com",
    "CacheSeconds": 60,
    "Auth": {
      "TokenEndpoint": "https://auth.pewi.se/oidc/token",
      "ClientId": "rtw4yg2ibima9ss33i2wc",
      "GrantType": "client_credentials",
      "Resource": "https://api.pdf-ingest.pewi.se",
      "Scope": "api:read api:write",
      "ClientSecret": ""
    }
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:5173" ]
  }
}
