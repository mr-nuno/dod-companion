# Copy to backend/.env and fill in. Loaded into the api container via docker-compose env_file.
# Variable names are the app's config keys with the ASP.NET "__" section separator.

# OAuth2 client-credentials secret for the Rules/PDF Search API.
RulesApi__Auth__ClientSecret=

# Resend (https://resend.com) API key for sending create-session magic links.
# Leave empty to run in log-only mode (the link is written to the app logs instead of emailed).
Resend__ApiKey=

# Allowlisted Game Master (SL) emails permitted to request a create-session link.
# Add one line per allowed address, incrementing the index.
Sessions__AllowedDmEmails__0=
