# Copy to `.env` and fill in the secret(s). Loaded by docker-compose into the container.
# Variable names are configuration keys with the ASP.NET double-underscore section separator.

# OAuth2 client-credentials secret for the outbound Rules API token (never commit the real value).
RulesApi__Auth__ClientSecret=

# The Logto API resource identifier this server validates inbound tokens against
# (audience of the JWT presented by MCP clients on /sse).
Logto__Audience=
